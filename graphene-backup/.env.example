TZ=Europe/Amsterdam
UID=   # id -u
GID=

# NordVPN access token (generate at https://my.nordaccount.com/dashboard/nordvpn/access-tokens/)
NORDVPN_TOKEN=

# Meshnet nickname — reachable as <nickname>.nord from other mesh peers
MESHNET_NICKNAME=graphene-backup

# Sync schedule (cron expression for periodic sync to Proton Drive)
SYNC_SCHEDULE=0 */6 * * *

# HTTPS reverse proxy (Caddy with self-signed TLS)
HTTPS_PORT=8443
HOSTNAME=backup.lan

# WebDAV (used by GrapheneOS Seedvault to connect)
WEBDAV_USER=graphene
WEBDAV_PASS=

# Proton Drive
PROTON_REMOTE_PATH=graphene-backups

